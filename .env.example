# FastAPI Configuration
APP_NAME=Newsgroup-Semantic-Explorer
APP_VERSION=1.0.0
DEBUG=False
LOG_LEVEL=INFO

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Dataset Configuration
# Options: 20_newsgroups or mini_newsgroups
# Set NEWSGROUPS_PATH to override default location
DATASET_TYPE=20_newsgroups
NEWSGROUPS_PATH=

# Embedding Configuration
# Options: lsa (default) or neural
EMBEDDING_TYPE=lsa

# Cache Configuration
CACHE_ENABLED=True
CACHE_THETA_LSA=0.60
CACHE_THETA_NEURAL=0.88

# Security Configuration
CORS_ORIGINS=*
ALLOWED_HOSTS=*
REQUIRE_HTTPS=False

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Logging Configuration
LOG_FILE_PATH=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
